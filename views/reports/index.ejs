<!DOCTYPE html>
<html lang="en">
<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Reports</title>

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial,sans-serif;
}

body{
background:#F4F2FF;
}

.container{
width:95%;
margin:30px auto;
}

.header{
display:flex;
justify-content:space-between;
align-items:center;
margin-bottom:25px;
}

.header h1{
color:#6C63FF;
}

.btn{
background:#6C63FF;
color:white;
padding:12px 20px;
text-decoration:none;
border-radius:8px;
font-weight:bold;
}

.btn:hover{
background:#564fd8;
}

table{
width:100%;
background:white;
border-collapse:collapse;
box-shadow:0 5px 12px rgba(0,0,0,.15);
}

th{
background:#6C63FF;
color:white;
padding:15px;
}

td{
padding:15px;
text-align:center;
border-bottom:1px solid #eee;
}

tr:hover{
background:#f8f7ff;
}

.action-btn{

padding:8px 14px;
color:white;
text-decoration:none;
border-radius:6px;
margin:2px;

}

.view{
background:#3b82f6;
}

.edit{
background:#f59e0b;
}

.delete{
background:#ef4444;
border:none;
cursor:pointer;
}

form{
display:inline;
}

</style>

</head>

<body>

<div class="container">

<div class="header">

<h1>Reports</h1>

<a
href="/reports/new"
class="btn">

+ Generate Report

</a>

</div>

<table>

<tr>

<th>Title</th>

<th>Type</th>

<th>Generated By</th>

<th>Date</th>

<th>Total Assets</th>

<th>Allocated</th>

<th>Available</th>

<th>Action</th>

</tr>

<% reports.forEach((report)=>{ %>

<tr>

<td>

<%= report.reportTitle %>

</td>

<td>

<%= report.reportType %>

</td>

<td>

<%= report.generatedBy %>

</td>

<td>

<%= report.reportDate.toDateString() %>

</td>

<td>

<%= report.totalAssets %>

</td>

<td>

<%= report.allocatedAssets %>

</td>

<td>

<%= report.availableAssets %>

</td>

<td>

<a
href="/reports/<%= report._id %>"
class="action-btn view">

View

</a>

<a
href="/reports/<%= report._id %>/edit"
class="action-btn edit">

Edit

</a>

<form
action="/reports/<%= report._id %>?_method=DELETE"
method="POST">

<button
class="action-btn delete">

Delete

</button>

</form>

</td>

</tr>

<% }) %>

</table>

</div>

</body>
</html>