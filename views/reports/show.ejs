<!DOCTYPE html>
<html lang="en">
<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Report Details</title>

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial,sans-serif;
}

body{
background:#F4F2FF;
}

.container{

width:700px;
margin:40px auto;
background:white;
padding:30px;
border-radius:12px;
box-shadow:0 5px 15px rgba(0,0,0,.15);

}

h1{

text-align:center;
color:#6C63FF;
margin-bottom:30px;

}

.card{

border:1px solid #ddd;
border-radius:10px;
padding:20px;

}

.row{

display:flex;
justify-content:space-between;
padding:14px 0;
border-bottom:1px solid #eee;

}

.row:last-child{

border-bottom:none;

}

.title{

font-weight:bold;
color:#555;

}

.value{

color:#222;

}

.buttons{

margin-top:30px;
display:flex;
justify-content:space-between;

}

.btn{

padding:12px 22px;
text-decoration:none;
border-radius:8px;
color:white;
font-weight:bold;

}

.back{

background:#6C63FF;

}

.edit{

background:#3B82F6;

}

</style>

</head>

<body>

<div class="container">

<h1>Report Details</h1>

<div class="card">

<div class="row">

<div class="title">Report Title</div>

<div class="value">

<%= report.reportTitle %>

</div>

</div>

<div class="row">

<div class="title">Report Type</div>

<div class="value">

<%= report.reportType %>

</div>

</div>

<div class="row">

<div class="title">Generated By</div>

<div class="value">

<%= report.generatedBy %>

</div>

</div>

<div class="row">

<div class="title">Report Date</div>

<div class="value">

<%= report.reportDate.toDateString() %>

</div>

</div>

<div class="row">

<div class="title">Total Assets</div>

<div class="value">

<%= report.totalAssets %>

</div>

</div>

<div class="row">

<div class="title">Allocated Assets</div>

<div class="value">

<%= report.allocatedAssets %>

</div>

</div>

<div class="row">

<div class="title">Available Assets</div>

<div class="value">

<%= report.availableAssets %>

</div>

</div>

<div class="row">

<div class="title">Remarks</div>

<div class="value">

<%= report.remarks %>

</div>

</div>

</div>

<div class="buttons">

<a
href="/reports"
class="btn back">

← Back

</a>

<a
href="/reports/<%= report._id %>/edit"
class="btn edit">

Edit Report

</a>

</div>

</div>

</body>
</html>