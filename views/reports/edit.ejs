<!DOCTYPE html>
<html lang="en">
<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Edit Report</title>

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial,sans-serif;
}

body{
background:#F4F2FF;
}

.container{

width:650px;
margin:40px auto;
background:white;
padding:30px;
border-radius:12px;
box-shadow:0 5px 15px rgba(0,0,0,.15);

}

h1{

text-align:center;
color:#6C63FF;
margin-bottom:30px;

}

.form-group{

margin-bottom:18px;

}

label{

display:block;
margin-bottom:8px;
font-weight:bold;

}

input,
select,
textarea{

width:100%;
padding:12px;
border:1px solid #ccc;
border-radius:8px;

}

textarea{

height:100px;

}

button{

width:100%;
padding:15px;
background:#6C63FF;
color:white;
border:none;
border-radius:8px;
font-size:17px;
cursor:pointer;

}

button:hover{

background:#564fd8;

}

.back{

display:inline-block;
margin-top:20px;
text-decoration:none;
color:#6C63FF;
font-weight:bold;

}

</style>

</head>

<body>

<div class="container">

<h1>Edit Report</h1>

<form
action="/reports/<%= report._id %>?_method=PUT"
method="POST">

<div class="form-group">

<label>Report Title</label>

<input
type="text"
name="report[reportTitle]"
value="<%= report.reportTitle %>"
required>

</div>

<div class="form-group">

<label>Report Type</label>

<select name="report[reportType]">

<option value="Asset" <%= report.reportType=="Asset"?"selected":"" %>>Asset</option>

<option value="Booking" <%= report.reportType=="Booking"?"selected":"" %>>Booking</option>

<option value="Maintenance" <%= report.reportType=="Maintenance"?"selected":"" %>>Maintenance</option>

<option value="Allocation" <%= report.reportType=="Allocation"?"selected":"" %>>Allocation</option>

</select>

</div>

<div class="form-group">

<label>Generated By</label>

<input
type="text"
name="report[generatedBy]"
value="<%= report.generatedBy %>"
required>

</div>

<div class="form-group">

<label>Report Date</label>

<input
type="date"
name="report[reportDate]"
value="<%= report.reportDate.toISOString().split('T')[0] %>"
required>

</div>

<div class="form-group">

<label>Total Assets</label>

<input
type="number"
name="report[totalAssets]"
value="<%= report.totalAssets %>"
required>

</div>

<div class="form-group">

<label>Allocated Assets</label>

<input
type="number"
name="report[allocatedAssets]"
value="<%= report.allocatedAssets %>"
required>

</div>

<div class="form-group">

<label>Available Assets</label>

<input
type="number"
name="report[availableAssets]"
value="<%= report.availableAssets %>"
required>

</div>

<div class="form-group">

<label>Remarks</label>

<textarea
name="report[remarks]"><%= report.remarks %></textarea>

</div>

<button>

Update Report

</button>

</form>

<a href="/reports" class="back">

← Back to Reports

</a>

</div>

</body>
</html>