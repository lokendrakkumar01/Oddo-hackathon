<!DOCTYPE html>
<html lang="en">
<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Booking Details</title>

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial, Helvetica, sans-serif;
}

body{
background:#F4F2FF;
}

.container{

width:700px;
margin:40px auto;
background:white;
padding:30px;
border-radius:12px;
box-shadow:0 5px 15px rgba(0,0,0,.15);

}

h1{

text-align:center;
margin-bottom:30px;
color:#6C63FF;

}

.card{

display:grid;
grid-template-columns:180px 1fr;
row-gap:20px;
column-gap:20px;

}

.label{

font-weight:bold;
color:#555;

}

.value{

color:#222;

}

.btn{

display:inline-block;
margin-top:30px;
padding:12px 20px;
background:#6C63FF;
color:white;
text-decoration:none;
border-radius:8px;

}

.btn:hover{

background:#5848e5;

}

</style>

</head>

<body>

<div class="container">

<h1>Booking Details</h1>

<div class="card">

<div class="label">Employee</div>
<div class="value"><%= booking.employeeName %></div>

<div class="label">Resource</div>
<div class="value"><%= booking.resourceName %></div>

<div class="label">Booking Date</div>
<div class="value"><%= booking.bookingDate.toDateString() %></div>

<div class="label">Start Time</div>
<div class="value"><%= booking.startTime %></div>

<div class="label">End Time</div>
<div class="value"><%= booking.endTime %></div>

<div class="label">Purpose</div>
<div class="value"><%= booking.purpose %></div>

<div class="label">Status</div>
<div class="value"><%= booking.status %></div>

</div>

<a href="/bookings" class="btn">← Back</a>

</div>

</body>
</html>