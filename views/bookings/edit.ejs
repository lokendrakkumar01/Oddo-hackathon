<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Edit Booking</title>

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial,sans-serif;
}

body{
background:#F4F2FF;
}

.container{

width:650px;
margin:40px auto;
background:white;
padding:30px;
border-radius:12px;
box-shadow:0 5px 15px rgba(0,0,0,.15);

}

h1{

text-align:center;
color:#6C63FF;
margin-bottom:30px;

}

.form-group{

margin-bottom:18px;

}

label{

display:block;
margin-bottom:8px;
font-weight:bold;

}

input,
select,
textarea{

width:100%;
padding:12px;
border:1px solid #ccc;
border-radius:8px;

}

textarea{

height:100px;

}

button{

width:100%;
padding:15px;
background:#6C63FF;
color:white;
border:none;
border-radius:8px;
font-size:17px;
cursor:pointer;

}

button:hover{

background:#5649e0;

}

.back{

display:inline-block;
margin-top:20px;
text-decoration:none;
color:#6C63FF;

}

</style>

</head>

<body>

<div class="container">

<h1>Edit Booking</h1>

<form action="/bookings/<%= booking._id %>?_method=PUT" method="POST">

<div class="form-group">

<label>Employee Name</label>

<input
type="text"
name="booking.employeeName"
value="<%= booking.employeeName %>"
required>

</div>

<div class="form-group">

<label>Resource</label>

<input
type="text"
name="booking.resourceName"
value="<%= booking.resourceName %>"
required>

</div>

<div class="form-group">

<label>Booking Date</label>

<input
type="date"
name="booking.bookingDate"
value="<%= booking.bookingDate.toISOString().split('T')[0] %>"
required>

</div>

<div class="form-group">

<label>Start Time</label>

<input
type="time"
name="booking.startTime"
value="<%= booking.startTime %>"
required>

</div>

<div class="form-group">

<label>End Time</label>

<input
type="time"
name="booking.endTime"
value="<%= booking.endTime %>"
required>

</div>

<div class="form-group">

<label>Purpose</label>

<textarea
name="booking.purpose"
required><%= booking.purpose %></textarea>

</div>

<div class="form-group">

<label>Status</label>

<select name="booking.status">

<option value="Upcoming"
<%= booking.status==="Upcoming"?"selected":"" %>>
Upcoming
</option>

<option value="Approved"
<%= booking.status==="Approved"?"selected":"" %>>
Approved
</option>

<option value="Completed"
<%= booking.status==="Completed"?"selected":"" %>>
Completed
</option>

<option value="Cancelled"
<%= booking.status==="Cancelled"?"selected":"" %>>
Cancelled
</option>

</select>

</div>

<button>

Update Booking

</button>

</form>

<a href="/bookings" class="back">

← Back to Booking List

</a>

</div>

</body>
</html>