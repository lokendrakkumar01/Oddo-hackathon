<!DOCTYPE html>
<html lang="en">
<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>AssetFlow | Sign Up</title>

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial,Helvetica,sans-serif;
}

body{

display:flex;
justify-content:center;
align-items:center;
height:100vh;
background:#f4f2ff;

}

.container{

width:420px;
background:#fff;
padding:35px;
border-radius:15px;
box-shadow:0 5px 15px rgba(0,0,0,.2);

}

h1{

text-align:center;
color:#6C63FF;
margin-bottom:25px;

}

.form-group{

margin-bottom:18px;

}

label{

display:block;
margin-bottom:8px;
font-weight:bold;

}

input{

width:100%;
padding:12px;
border:1px solid #ccc;
border-radius:8px;
font-size:15px;

}

button{

width:100%;
padding:14px;
background:#6C63FF;
color:#fff;
border:none;
border-radius:8px;
font-size:17px;
cursor:pointer;
margin-top:10px;

}

button:hover{

background:#564fd8;

}

p{

margin-top:20px;
text-align:center;

}

a{

color:#6C63FF;
text-decoration:none;
font-weight:bold;

}

</style>

</head>

<body>

<div class="container">

<h1>Create Account</h1>

<form action="/signup" method="POST">

<div class="form-group">

<label>Full Name</label>

<input
type="text"
name="name"
placeholder="Enter Full Name"
required>

</div>

<div class="form-group">

<label>Email</label>

<input
type="email"
name="email"
placeholder="Enter Email"
required>

</div>

<div class="form-group">

<label>Password</label>

<input
type="password"
name="password"
placeholder="Enter Password"
required>

</div>

<button>

Sign Up

</button>

</form>

<p>

Already have an account?

<a href="/signin">

Sign In

</a>

</p>

</div>

</body>
</html>