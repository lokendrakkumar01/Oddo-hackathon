<!DOCTYPE html>
<html lang="en">
<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>AssetFlow | Sign In</title>

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial,Helvetica,sans-serif;
}

body{

display:flex;
justify-content:center;
align-items:center;
height:100vh;
background:#F4F2FF;

}

.container{

width:420px;
background:white;
padding:35px;
border-radius:15px;
box-shadow:0 5px 15px rgba(0,0,0,.15);

}

h1{

text-align:center;
color:#6C63FF;
margin-bottom:25px;

}

.form-group{

margin-bottom:18px;

}

label{

display:block;
margin-bottom:8px;
font-weight:bold;

}

input{

width:100%;
padding:12px;
border:1px solid #ccc;
border-radius:8px;
font-size:15px;

}

.options{

display:flex;
justify-content:space-between;
align-items:center;
margin-bottom:20px;

}

.options label{

display:flex;
align-items:center;
gap:5px;
font-size:14px;

}

.options input{

width:auto;

}

.options a{

text-decoration:none;
color:#6C63FF;
font-size:14px;

}

button{

width:100%;
padding:14px;
background:#6C63FF;
color:white;
border:none;
border-radius:8px;
font-size:17px;
cursor:pointer;

}

button:hover{

background:#564fd8;

}

.signup{

margin-top:20px;
text-align:center;

}

.signup a{

text-decoration:none;
color:#6C63FF;
font-weight:bold;

}

</style>

</head>

<body>

<div class="container">

<h1>Sign In</h1>

<form action="/signin" method="POST">

<div class="form-group">

<label>Email</label>

<input
type="email"
name="email"
placeholder="Enter Email"
required>

</div>

<div class="form-group">

<label>Password</label>

<input
type="password"
name="password"
placeholder="Enter Password"
required>

</div>

<div class="options">

<label>

<input
type="checkbox">

Remember Me

</label>

<a href="#">

Forgot Password?

</a>

</div>

<button type="submit">

Sign In

</button>

</form>

<div class="signup">

Don't have an account?

<a href="/signup">

Create Account

</a>

</div>

</div>

</body>
</html>