<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">


    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Font Awesome -->
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">

    <!-- Dashboard CSS -->
    <link rel="stylesheet" href="/css/dashboard.css">
</head>

<body>

<div class="dashboard">
<%- include("../includes/slidebar") %>
<div class="main-content">
    <%- include("../includes/navbar") %>
<body>
  <h2>Assest Management</h2>
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold text-primary">Assets</h2>

    <a href="/assets/new" class="btn btn-primary">
        <i class="fa-solid fa-plus"></i> Add Asset
    </a>
</div>
  <a href = "/asset/new">Add new Assest</a>
  <div class="card">

    <div class="card-header">
        Asset List
    </div>

    <div class="card-body">

  <table>
    <thead><tr>
      <th>Assest Tag</th>
      <th>Assest Name</th>
      <th>Category</th>
      <th>Status</th>
      <th>Location</th>
      <th>Action</th>
    </tr></thead>
    <tbody>

            <% if (assets && assets.length > 0) { %>

                <% assets.forEach(asset => { %>

                    <tr>

                        <td><%= asset.assetTag %></td>

                        <td><%= asset.assetName %></td>

                        <td><%= asset.category %></td>

                        <td><%= asset.status %></td>

                        <td><%= asset.location %></td>

                        <td>

                            <a href="/assets/<%= asset._id %>">View</a>

                            <a href="/assets/<%= asset._id %>/edit">Edit</a>

                        </td>

                    </tr>

                <% }) %>

            <% } else { %>

                <tr>
                    <td colspan="6">No Assets Found</td>
                </tr>

            <% } %>

        </tbody>

    </table>
</div>
</div>
</body>
</html>
  </table>
</div>
</div>
</head>